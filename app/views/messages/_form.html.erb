<%= turbo_frame_tag "#{dom_id(chat)}_message_form" do %>
  <%= form_with(model: Message.new, url: [chat, chat.messages.new], class: "w-full") do |form| %>
    <div class="my-5">
      <%= form.text_area :content, rows: 4, id: "message_content",
        class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full",
        data: { chat_target: "textarea" },
        autofocus: true,
        "x-on:keydown.cmd.enter" => "$event.target.form.requestSubmit();" %>
    </div>

    <div class="grid justify-items-end">
      <div class="flex">
        <%= form.button type: :submit, class: "rounded-lg py-3 px-5 bg-blue-600 inline-block font-medium cursor-pointer" do %>
          <i class="fas fa-paper-plane"></i>
          <span class="pl-2">Send</span>
        <% end %>

        <%= link_to destroy_all_chat_messages_path(@chat), 
                    data: { "turbo-method": :delete},
                    class: "rounded-lg py-3 px-5 bg-indigo-200 inline-block font-medium cursor-pointer" do %>
          <i class="fas fa-trash"></i>
          <span class="pl-2">Clear All</span>
        <% end %>

      </div>
    </div>
  <% end %>
<% end %>

