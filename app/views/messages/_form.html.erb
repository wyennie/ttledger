<%= turbo_frame_tag "#{dom_id(chat)}_message_form" do %>
  <%= form_with(model: Message.new, url: [chat, chat.messages.new], class: "w-full") do |form| %>
    <div class="grid justify-items-end">
      <div class="flex">
        <%= link_to destroy_all_chat_messages_path(@chat), 
                    data: { "turbo-method": :delete},
                    class: "rounded-lg py-3 px-5 bg-indigo-200 inline-block font-medium cursor-pointer" do %>
          <i class="fas fa-trash"></i>
          <span class="pl-2">Clear All</span>
        <% end %>
      </div>
    </div>
    <div class="p-5 flex">
      <%= form.text_area :content, rows: 4, id: "message_content",
        class: "shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full",
        data: { chat_target: "textarea" },
        autofocus: true,
        "x-on:keydown.cmd.enter" => "$event.target.form.requestSubmit();" %>

      <%= form.button type: :submit, class: "rounded-lg py-3 px-5 bg-blue-600 font-medium cursor-pointer" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-indigo">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      <% end %>
    </div>

  <% end %>
<% end %>

