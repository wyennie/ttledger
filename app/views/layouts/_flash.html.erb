<div id="flash_messages">
  <% flash.each do |message_type, message| %>
    <% if message_type == "danger" %>
      <%= content_tag(:div, message, class: "alert-#{message_type} bg-red-100 border-red-400 text-red-700") %>
    <% else %>
      <%= content_tag(:div, message, class: "alert-#{message_type} bg-green-100 border-green-400 text-green-700") %>
    <% end %>
  <% end %>
</div>
