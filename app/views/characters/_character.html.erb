<div id="character_<%= character.id %>" class="space-y-2 mt-4 rounded shadow-md">
  <li class="w-full py-2 px-4 bg-slate-600 text-slate font-semibold rounded-lg 
                        shadow-md hover:bg-slate-800 focus:outline-none focus:ring-2 
                        focus:ring-slate-400 focus:ring-opacity-75 ml-auto" >

    <% if character.persisted? %>
      <%= link_to "#{character.name}", edit_campaign_character_path((@campaign || character.campaign), character), 
        class: "btn btn-secondary" %>

                    <% end %>
  </li>
</div>
