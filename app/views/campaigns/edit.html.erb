<h1 class="text-4xl font-bold text-center text-gray-800 mb-6">Edit campaign info</h1>
<div class="max-w-md mx-auto bg-white p-6 rounded-lg shadow-lg">
  <%= form_with(model: @campaign) do |f| %>
    <% render "shared/error_messages", object: @campaign %>

    <div class="mb-4">
      <%= f.label :name, "Title", class: "block text-lg font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full p-2 border border-gray-300 rounded-lg focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :description, class: "block text-lg font-medium text-gray-700" %>
      <%= f.text_field :description, class: "mt-1 block w-full p-2 border border-gray-300 rounded-lg focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>
    <div>
      <%= f.submit "Save changes", class: "w-full py-2 px-4 bg-indigo-500 text-white font-semibold rounded-lg shadow-md hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:ring-opacity-75" %>
    </div>
  <% end %>
  <br>
  <%= link_to "DELETE", @campaign, data: { "turbo-method": :delete,
                                           turbo_confirm: "Are you sure you want to delete this campaign?" },
                                           class: "w-full py-2 px-4 bg-red-500 text-white font-semibold rounded-lg shadow-md hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-opacity-75" %>
</div>
