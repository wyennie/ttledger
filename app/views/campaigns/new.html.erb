<h2 class="text-5xl font-semibold text-slate-400 mb-4">Create campaign</h2>
<div class="max-w-md mx-auto bg-slate-800 p-6 rounded-lg shadow-lg">
  <%= form_with(model: @campaign) do |f| %>
    <%= render 'shared/error_messages', object: @campaign %>

    <div class="mb-4">
      <%= f.label :name, "Title", class: "block text-lg font-medium text-slate-300" %>
      <%= f.text_field :name, class: "mt-1 block w-full p-2 border bg-slate-500 text-slate-300
      border-slate-600 rounded-lg focus:ring-slate-300 focus:border-slate-300" %>
    </div>

    <div class="mb-4">
      <%= f.label :description, class: "block text-lg font-medium text-slate-300" %>
      <%= f.text_area :description, class: "mt-1 block w-full p-2 border bg-slate-500 text-slate-300
      border-slate-600 rounded-lg focus:ring-slate-300 focus:border-slate-300" %>
    </div>

    <div>
      <%= f.submit "Create campaign", class: "w-full py-2 px-4 bg-slate-700 text-slate-100 font-semibold
      rounded-lg shadow-md hover:bg-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-opacity-75" %>
    </div>
  <% end %>
</div>
