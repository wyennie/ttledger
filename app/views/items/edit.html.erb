
<!-- app/views/items/edit.html.erb -->
<turbo-frame id="item-modal">
  <div class="fixed inset-0 bg-gray-500 bg-opacity-50 flex justify-center items-center">
    <div class="bg-white p-6 rounded-lg shadow-lg w-96">
      <h2 class="font-semibold text-xl mb-4">Edit Item</h2>
      
      <!-- Displaying validation error messages -->
      <%= render "shared/error_messages", object: @item %>
      
      <%= form_with model: [@campaign, @character, @item], url: campaign_character_item_path(@campaign, @character, @item), method: :patch, data: { turbo: true } do |f| %>
        
        <!-- Item Name -->
        <div class="mb-4">
          <%= f.label :name, "Item Name", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-emerald-500 focus:border-emerald-500" %>
        </div>
        
        <!-- Description -->
        <div class="mb-4">
          <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_area :description, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-emerald-500 focus:border-emerald-500", rows: 4 %>
        </div>

        <!-- Weight -->
        <div class="mb-4">
          <%= f.label :weight, "Weight (optional)", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :weight, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-emerald-500 focus:border-emerald-500" %>
        </div>

        <!-- Value -->
        <div class="mb-4">
          <%= f.label :value, "Value (optional)", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :value, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-emerald-500 focus:border-emerald-500" %>
        </div>

        <!-- Count -->
        <div class="mb-4">
          <%= f.label :count, "Quantity", class: "block text-sm font-medium text-gray-700" %>
          <%= f.number_field :count, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-emerald-500 focus:border-emerald-500" %>
        </div>

        <!-- Item Type (Dropdown) -->
        <div class="mb-4">
          <%= f.label :item_type, "Item Type", class: "block text-sm font-medium text-gray-700" %>
          <%= f.collection_select :item_type_id, ItemType.all, :id, :name, { prompt: "Select Item Type" }, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-emerald-500 focus:border-emerald-500" %>
        </div>

        <!-- Submit Button -->
        <div class="mb-4">
          <%= f.submit "Save Changes", class: "w-full py-2 px-4 bg-blue-500 text-white font-semibold rounded-lg shadow-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-75" %>
        </div>
        
      <% end %>

      <!-- Close Button -->
      <%= link_to "Close", "#", data: { turbo_frame: "item-modal" }, class: "text-sm text-blue-500 hover:text-blue-700 mt-2 block text-center" %>
    </div>
  </div>
</turbo-frame>
