# Copy to .env on the deploy host (chmod 600). Do not commit .env.
# .env is consumed by docker-compose.yml.

# Rails encrypted credentials master key (config/credentials/production.key locally).
RAILS_MASTER_KEY=

# Postgres password used for both the db container and the DATABASE_URL.
# DATABASE_URL is composed in docker-compose.yml from this value; you do not
# need to set DATABASE_URL here.
POSTGRES_PASSWORD=

# Demo Anthropic API key (used as fallback when a user hasn't supplied their own
# Anthropic or OpenAI key, rate-limited via LLMResolver::DEMO_DAILY_LIMIT).
ANTHROPIC_API_KEY=

# Optional: legacy OpenAI demo key (used only if a user has an OpenAI key set
# and no Anthropic key — kept for backward compatibility).
OPENAI_API_KEY=

# Postmark transactional email (used by UserMailer).
POSTMARK_API_TOKEN=
