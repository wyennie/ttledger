# Example of extracting secrets from 1password (or another compatible pw manager)
SECRETS=$(kamal secrets fetch --adapter 1password --account IEUWL6WIYFCENFVKHLVLZ7UA64 --from keys/Production KAMAL_REGISTRY_PASSWORD RAILS_MASTER_KEY POSTMARK_API_TOKEN OPENAI_API_KEY DB_HOST)
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
